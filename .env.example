# ─────────────────────────────────────────────────────────────────────────────
# Kebab SaaS V1 — Variables de entorno del frontend
# Copia este archivo a .env.local y rellena los valores reales.
# NUNCA subas .env o .env.local al repositorio (están en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (OBLIGATORIAS) ───────────────────────────────────────────────────
# URL del proyecto Supabase. La encuentras en:
# Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://<tu-project-ref>.supabase.co

# Clave anónima (pública). La encuentras en:
# Supabase Dashboard → Project Settings → API → anon / public
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Stripe (pagos online) ─────────────────────────────────────────────────────
# Activa la opción de pago online en el checkout.
# Debe coincidir con que STRIPE_SECRET_KEY esté configurado en Supabase Secrets.
VITE_STRIPE_ENABLED=false

# Clave pública de Stripe (pk_test_... o pk_live_...)
# La encuentras en: Stripe Dashboard → Developers → API keys → Publishable key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REEMPLAZAR

# ── URL pública del sitio (opcional) ─────────────────────────────────────────
# Si se omite, se usa window.location.origin automáticamente.
# Útil si el admin está en un subdominio diferente al storefront.
# En local: http://localhost:5173
# En producción: https://tudominio.com
# VITE_PUBLIC_URL=https://tudominio.com

# ── Landing page ─────────────────────────────────────────────────────────────
# URL de la landing page de marketing (proyecto separado).
# Se usa para el link "← Volver a la web" del panel admin y en login/registro.
# En producción: https://tudominio.com
# En local: http://localhost:3000 (ponlo en .env.local, no aquí)
VITE_LANDING_URL=https://tudominio.com

# ── Sentry (monitorización de errores en producción) ─────────────────────────
# Obtén el DSN en: https://sentry.io → Settings → Projects → <tu-proyecto> → DSN
# Si no configuras esto, los errores de producción no se reportarán.
# VITE_SENTRY_DSN=https://...@sentry.io/...

# ─────────────────────────────────────────────────────────────────────────────
# Supabase Secrets — se configuran en el proyecto de Supabase, NO aquí
# Panel → Settings → Edge Functions → Secrets, o via CLI:
#   supabase secrets set CLAVE=valor
# ─────────────────────────────────────────────────────────────────────────────
#
# STRIPE_SECRET_KEY         sk_test_...   Clave secreta de Stripe (NUNCA al frontend)
# STRIPE_WEBHOOK_SECRET     whsec_...     Secreto del webhook de Stripe
# SITE_URL                  https://...   URL base del sitio (para redirect URLs de Stripe)
#
# Secrets gestionados automáticamente por Supabase (no configurar manualmente):
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_ANON_KEY
# ─────────────────────────────────────────────────────────────────────────────
